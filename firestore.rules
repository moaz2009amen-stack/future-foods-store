rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // المنتجات — العميل يقرأ فقط، المالك يكتب
    match /products/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // الطلبات — العميل يكتب ويقرأ طلباته، المالك يكتب ويقرأ الكل
    match /orders/{doc} {
      allow create: if true;
      allow read: if true;
      allow update: if request.auth != null || request.resource.data.keys().hasOnly(['orderStatus']);
    }

    // الإعدادات — المالك فقط
    match /settings/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
